# Future server-side AI integration
# Do not expose this key to the browser.
GEMINI_API_KEY=""

# Optional server-side switch for AI provider
# Supported values: mock, gemini, bedrock
NAVIDESK_AI_PROVIDER="mock"

# Mock authenticated session role for internal environments
NAVIDESK_SESSION_ROLE="employee"

# AWS Bedrock Configuration
# Do not expose these credentials to the browser.
AWS_REGION="us-east-1"
AWS_BEDROCK_MODEL_ID="us.anthropic.claude-3-5-haiku-20241022-v1:0"

# Bedrock API Key (recommended, newer authentication method)
# Get from AWS Console > Bedrock > API Keys
BEDROCK_API_KEY=""

# Legacy IAM credentials (optional, use if API Key not available)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
